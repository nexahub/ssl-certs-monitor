# ── Frontend ───────────────────────────────────────────────
# URL publique de l'API (ex: https://api.mondomaine.com)
NXH_API_URL=https://api.mondomaine.com

# ── Backend ────────────────────────────────────────────────
API_URL=http://localhost:8000
NXH_DATABASE_HOST=localhost
NXH_DATABASE_PORT=3306
NXH_DATABASE_NAME=test
NXH_DATABASE_USER=test
NXH_DATABASE_PASSWORD=test

# ── Email Configuration ───────────────────────
NXH_SMTP_SERVER=smtp.gmail.com
NXH_SMTP_PORT=587
NXH_SMTP_SENDER_EMAIL=your-email@gmail.com
NXH_SMTP_PASSWORD=your-app-password
NXH_ALERT_RECIPIENTS=recipient@example.com